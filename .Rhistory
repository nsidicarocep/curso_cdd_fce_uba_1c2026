df_tasa_global <- tasa_global %>%
select(anio, valor) %>%
mutate(indicador = "Tasa global de fecundidad (hijos por mujer)")
df_tasa_adolescente <- tasa_adolescente_arg %>%
select(anio, valor) %>%
mutate(indicador = "Tasa fecundidad adolescente (por 1000 mujeres 15-19)")
View(tasa_global)
df_tasa_global <- tasa_global %>%
select(anio, valor=tgf) %>%
mutate(indicador = "Tasa global de fecundidad (hijos por mujer)")
df_tasa_adolescente <- tasa_adolescente_arg %>%
select(anio, valor=tgf_adolescente) %>%
mutate(indicador = "Tasa fecundidad adolescente (por 1000 mujeres 15-19)")
df_edad_maternidad <- edad_maternidad_arg %>%
select(anio, valor=edad_media_maternidad) %>%
mutate(indicador = "Edad media de la maternidad (años)")
# Unir todos los datos en un solo dataframe
datos_consolidados <- bind_rows(
df_tasa_global,
df_tasa_adolescente,
df_edad_maternidad
) %>%
arrange(indicador, anio)
# Guardar CSV consolidado
write_csv(datos_consolidados, "indicadores_fecundidad_argentina.csv")
View(df_edad_maternidad)
df_edad_maternidad <- edad_maternidad_arg %>%
filter(anio <= 2025) %>%
select(anio, valor=edad_media_maternidad) %>%
mutate(indicador = "Edad media de la maternidad (años)")
View(df_edad_maternidad)
# También guardar versión en formato ancho (wide) para facilitar comparaciones
datos_wide <- datos_consolidados %>%
pivot_wider(
names_from = indicador,
values_from = valor
) %>%
arrange(anio)
write_csv(datos_wide, "indicadores_fecundidad_argentina_wide.csv")
